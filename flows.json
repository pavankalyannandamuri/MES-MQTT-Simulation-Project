    {
        "id": "fn_mes_logic_1",
        "type": "function",
        "z": "tab_mes_logic_1",
        "name": "MES Logic",
        "func": "let data = flow.get('mesData') || {\n    state: 'UNKNOWN',\n    count: 0,\n    temp: 0,\n    downtimeSeconds: 0,\n    runtimeSeconds: 0,\n    goodCount: 0,\n    rejectCount: 0,\n    idealRunRatePerMin: 150,\n    startTs: Date.now(),\n    lastTs: Date.now(),\n    lastCount: 0\n};\n\nconst now = Date.now();\nlet elapsed = (now - data.lastTs) / 1000;\nif (elapsed < 0 || elapsed > 10) elapsed = 0;\ndata.lastTs = now;\n\nif (msg.topic.endsWith('/state')) {\n    data.state = String(msg.payload);\n}\nif (msg.topic.endsWith('/count')) {\n    data.count = Number(msg.payload);\n}\nif (msg.topic.endsWith('/temp')) {\n    data.temp = Number(msg.payload);\n}\n\nif (data.state === 'RUNNING') {\n    data.runtimeSeconds += elapsed;\n} else if (data.state === 'STOPPED') {\n    data.downtimeSeconds += elapsed;\n}\n\nconst producedDelta = Math.max(0, data.count - data.lastCount);\ndata.lastCount = data.count;\n\nif (producedDelta > 0) {\n    const rejects = Math.random() < 0.15 ? 1 : 0;\n    const good = Math.max(0, producedDelta - rejects);\n    data.goodCount += good;\n    data.rejectCount += rejects;\n}\n\nconst plannedTime = data.runtimeSeconds + data.downtimeSeconds;\nconst availability = plannedTime > 0 ? data.runtimeSeconds / plannedTime : 0;\nconst actualRatePerMin = data.runtimeSeconds > 0 ? (data.count / data.runtimeSeconds) * 60 : 0;\nconst performance = data.idealRunRatePerMin > 0 ? actualRatePerMin / data.idealRunRatePerMin : 0;\nconst totalProduced = data.goodCount + data.rejectCount;\nconst quality = totalProduced > 0 ? data.goodCount / totalProduced : 1;\nconst oee = availability * performance * quality;\n\nconst out = {\n    state: data.state,\n    count: data.count,\n    temp: data.temp,\n    runtimeSeconds: Math.floor(data.runtimeSeconds),\n    downtimeSeconds: Math.floor(data.downtimeSeconds),\n    goodCount: data.goodCount,\n    rejectCount: data.rejectCount,\n    availability: Number((availability * 100).toFixed(2)),\n    performance: Number((performance * 100).toFixed(2)),\n    quality: Number((quality * 100).toFixed(2)),\n    oee: Number((oee * 100).toFixed(2))\n};\n\nglobal.set('mesData', data);\nreturn { payload: out };",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
