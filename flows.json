    {
        "id": "function1",
        "type": "function",
        "z": "dc07687401529c2f",
        "name": "Machine Simulator",
        "func": "let count = flow.get(\"count\") || 0;\nlet running = flow.get(\"running\");\n\nif (running === undefined) running = true;\n\nif (Math.random() < 0.2) running = !running;\n\nif (running) count += 5;\n\nlet temp = running ? (70 + Math.random()*10) : (60 + Math.random()*5);\n\nflow.set(\"count\", count);\nflow.set(\"running\", running);\n\nreturn [\n { topic: \"plant1/line1/machine01/state\", payload: running ? \"RUNNING\" : \"STOPPED\" },\n { topic: \"plant1/line1/machine01/count\", payload: count },\n { topic: \"plant1/line1/machine01/temp\", payload: Number(temp.toFixed(1)) }\n];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 290,
        "y": 440,
        "wires": [
            [
                "mqtt1"
            ],
            [
                "mqtt2"
            ],
            [
                "mqtt3"
            ]
        ]
    },
